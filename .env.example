# Copy this file to .env and fill in real values before deploying
# NEVER commit .env to git

# Used by auth-service, user-service, workout-service
JWT_SECRET=replace_with_a_long_random_secret_string

# Used by ai-agent-service (Python / LangChain chatbot)
GOOGLE_API_KEY=replace_with_your_google_ai_api_key
# Required: set the Gemini model name (check https://ai.google.dev/gemini-api/docs/models)
LLM_MODEL=gemini-2.5-flash-lite
